<!-- pages/add-record/add-record.wxml -->
<navigation-bar title="记账" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="add-record-container">
    <!-- 上传区域 -->
    <view class="upload-section">
      <view class="upload-box" bindtap="chooseImage">
        <block wx:if="{{!imageUrl}}">
          <text class="upload-icon">📷</text>
          <text class="upload-text">{{uploadMode === 'camera' ? '拍照上传' : '选择图片'}}</text>
          <text class="upload-hint">支持支付截图自动识别</text>
        </block>
        <block wx:else>
          <image class="preview-image" src="{{imageUrl}}" mode="aspectFit"></image>
          <view class="reupload-btn" bindtap="chooseImage" catchtap>
            <text>重新上传</text>
          </view>
        </block>
      </view>

      <!-- 上传方式切换 -->
      <view class="upload-mode-switch" wx:if="{{!imageUrl}}">
        <view
          class="mode-item {{uploadMode === 'album' ? 'active' : ''}}"
          bindtap="switchUploadMode"
          data-mode="album"
        >
          <text class="mode-icon">🖼️</text>
          <text class="mode-text">相册</text>
        </view>
        <view
          class="mode-item {{uploadMode === 'camera' ? 'active' : ''}}"
          bindtap="switchUploadMode"
          data-mode="camera"
        >
          <text class="mode-icon">📸</text>
          <text class="mode-text">拍照</text>
        </view>
      </view>
    </view>

    <!-- 识别结果展示 -->
    <view class="result-section" wx:if="{{recognizedData && !showManualInput}}">
      <view class="result-header">
        <text class="result-title">识别结果</text>
        <text class="result-tag">AI自动识别</text>
      </view>

      <view class="result-item">
        <text class="result-label">金额</text>
        <input
          class="result-input amount-input"
          type="digit"
          value="{{recognizedData.amount}}"
          bindinput="onAmountChange"
          placeholder="请输入金额"
        />
      </view>

      <view class="result-item">
        <text class="result-label">时间</text>
        <picker
          mode="multiSelector"
          range="{{[dateRange, timeRange]}}"
          bindchange="onTimeChange"
        >
          <view class="result-input">{{formatTime(recognizedData.paymentTime)}}</view>
        </picker>
      </view>

      <view class="result-item">
        <text class="result-label">分类</text>
        <picker
          mode="selector"
          range="{{categories}}"
          range-key="name"
          value="{{recognizedData.categoryIndex}}"
          bindchange="onCategoryChange"
        >
          <view class="result-input category-input">
            <text class="category-icon" style="color: {{recognizedData.categoryColor}}">{{recognizedData.categoryIcon}}</text>
            <text>{{recognizedData.categoryName}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="result-item" wx:if="{{recognizedData.merchantName}}">
        <text class="result-label">商户</text>
        <input
          class="result-input"
          value="{{recognizedData.merchantName}}"
          bindinput="onMerchantChange"
          placeholder="商户名称（选填）"
        />
      </view>
    </view>

    <!-- 手动输入区域（降级方案） -->
    <view class="manual-section" wx:if="{{showManualInput}}">
      <view class="section-header">
        <text class="section-title">手动输入</text>
      </view>

      <view class="form-item">
        <text class="form-label">金额 *</text>
        <input
          class="form-input"
          type="digit"
          placeholder="请输入金额"
          value="{{manualData.amount}}"
          bindinput="onManualAmountChange"
        />
      </view>

      <view class="form-item">
        <text class="form-label">时间 *</text>
        <picker
          mode="multiSelector"
          range="{{[dateRange, timeRange]}}"
          value="{{manualData.categoryIndex}}"
          bindchange="onManualTimeChange"
        >
          <view class="form-input-picker">{{formatTime(manualData.paymentTime)}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">分类 *</text>
        <picker
          mode="selector"
          range="{{categories}}"
          range-key="name"
          value="{{manualData.categoryIndex}}"
          bindchange="onManualCategoryChange"
        >
          <view class="form-input-picker">
            <text class="category-icon" style="color: {{manualData.categoryColor}}">{{manualData.categoryIcon}}</text>
            <text>{{manualData.categoryName}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">备注</text>
        <input
          class="form-input"
          placeholder="请输入备注（选填）"
          value="{{manualData.remark}}"
          bindinput="onManualRemarkChange"
        />
      </view>
    </view>

    <!-- 降级方案按钮 -->
    <view class="fallback-btn" bindtap="showManualInput" wx:if="{{!showManualInput}}">
      <text>手动输入</text>
    </view>
  </view>
</scroll-view>

<!-- 底部操作栏 -->
<view class="bottom-actions">
  <view class="btn btn-cancel" bindtap="onCancel">取消</view>
  <view class="btn btn-confirm" bindtap="onConfirm">确认记账</view>
</view>
