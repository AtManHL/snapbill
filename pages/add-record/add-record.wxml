<view class="add-record-page">
  <!-- 导航栏 -->
  <view class="nav-header">
    <view class="nav-back" bindtap="onCancel">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">添加记账</text>
  </view>

  <!-- 上传区域 -->
  <view class="upload-section" wx:if="{{!isUploading && !recognizedData}}">
    <view class="upload-icon-large">
      <text>🖼️</text>
    </view>

    <text class="upload-title">上传支付截图</text>
    <text class="upload-hint">AI将自动识别金额、时间和分类</text>

    <view class="upload-buttons">
      <view class="btn-primary" bindtap="chooseImageFromAlbum">
        <text>📂 从相册选择</text>
      </view>
      <view class="btn-secondary" bindtap="chooseImageFromCamera">
        <text>📷 拍照上传</text>
      </view>
    </view>

    <view class="manual-link" bindtap="showManualInput">
      <text>手动输入</text>
    </view>
  </view>

  <!-- AI识别中 -->
  <view class="upload-loading" wx:if="{{isUploading}}">
    <view class="loading-spinner-large"></view>
    <text class="loading-title">AI识别中...</text>
    <text class="loading-hint">正在提取支付信息</text>
  </view>

  <!-- 识别结果/手动输入 -->
  <scroll-view class="form-scroll" scroll-y wx:if="{{recognizedData || showManualInput}}">
    <view class="form-section">
      <!-- AI提示 -->
      <view class="ai-notice" wx:if="{{recognizedData && !showManualInput}}">
        <text class="ai-text">✨ AI已自动识别支付信息，请确认后提交</text>
      </view>

      <!-- 金额输入 -->
      <view class="form-item">
        <text class="form-label">支付金额</text>
        <view class="amount-input-wrapper">
          <text class="currency">¥</text>
          <input
            class="amount-input"
            type="digit"
            value="{{showManualInput ? manualData.amount : recognizedData.amount}}"
            bindinput="onAmountChange"
            placeholder="0.00"
          />
        </view>
      </view>

      <!-- 分类选择 -->
      <view class="form-item">
        <text class="form-label">消费分类</text>
        <picker
          mode="selector"
          range="{{categories}}"
          range-key="name"
          value="{{showManualInput ? manualData.categoryIndex : recognizedData.categoryIndex}}"
          bindchange="onCategoryChange"
        >
          <view class="category-picker">
            <text class="picker-icon">{{showManualInput ? manualData.categoryIcon : recognizedData.categoryIcon}}</text>
            <text class="picker-text">{{showManualInput ? manualData.categoryName : recognizedData.categoryName}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 商户名称 -->
      <view class="form-item">
        <text class="form-label">商户名称（可选）</text>
        <input
          class="form-input"
          value="{{showManualInput ? manualData.merchantName : recognizedData.merchantName}}"
          bindinput="onMerchantChange"
          placeholder="如：美团外卖"
        />
      </view>

      <!-- 支付时间 -->
      <view class="form-item">
        <text class="form-label">支付时间</text>
        <picker
          mode="multiSelector"
          range="{{[dateRange, timeRange]}}"
          bindchange="onTimeChange"
        >
          <view class="time-picker">
            <text class="picker-text">{{formatTime(showManualInput ? manualData.paymentTime : recognizedData.paymentTime)}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-actions" wx:if="{{recognizedData || showManualInput}}">
    <view class="btn-cancel" bindtap="onCancel">取消</view>
    <view class="btn-confirm" bindtap="onConfirm">确认记账</view>
  </view>
</view>
