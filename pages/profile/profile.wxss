.profile-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-top: 88rpx;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 40rpx 32rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nick-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.remark {
  font-size: 24rpx;
  color: #999999;
}

.edit-remark {
  padding: 12rpx 24rpx;
  background-color: #45B7D1;
  border-radius: 24rpx;
}

.edit-remark text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 统计数据 */
.stats-card {
  background-color: #ffffff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.stats-items {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.stats-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #45B7D1;
}

/* 功能菜单 */
.menu-section {
  background-color: #ffffff;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-title {
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 48rpx;
  color: #cccccc;
  transform: rotate(90deg);
}

/* 退出登录 */
.logout-section {
  margin-top: 48rpx;
  padding: 0 32rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  border: 2rpx solid #FF6B6B;
}

.logout-btn text {
  font-size: 28rpx;
  color: #FF6B6B;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-text {
  font-size: 28rpx;
  color: #ffffff;
}
