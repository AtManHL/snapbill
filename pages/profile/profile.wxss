/* pages/profile/profile.wxss */
page {
  height: 100vh;
  background: linear-gradient(180deg, rgba(239, 246, 255, 0.5) 0%, #ffffff 100%);
}

.profile-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 48rpx 32rpx;
  border-bottom: 2rpx solid #dbeafe;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dbeafe 0%, #e9d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #3b82f6;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
  overflow: hidden;
}

/* 用户卡片 */
.user-card {
  margin: 32rpx 48rpx;
  padding: 48rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #ec4899 100%);
  box-shadow: 0 16rpx 48rpx rgba(59, 130, 246, 0.3);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.user-avatar text {
  font-size: 64rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-type {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-stats {
  display: flex;
  gap: 48rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-box .stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stat-box .stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 区块 */
.section {
  margin: 0 48rpx 48rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 24rpx;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f3f4f6;
}

.menu-card:active {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.menu-icon.blue {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.menu-icon.purple {
  background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%);
}

.menu-icon.yellow {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.menu-icon.green {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
}

.menu-icon.indigo {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
}

.menu-icon.teal {
  background: linear-gradient(135deg, #ccfbf1 0%, #99f6e4 100%);
}

.menu-icon text {
  font-size: 40rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #374151;
}

.menu-extra {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.extra-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.menu-arrow {
  font-size: 36rpx;
  color: #9ca3af;
}

/* 退出登录 */
.logout-section {
  margin: 0 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.logout-btn {
  width: 100%;
  height: 112rpx;
  border-radius: 32rpx;
  border: 4rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.logout-btn:active {
  background: #f9fafb;
}

.logout-btn text {
  font-size: 30rpx;
  color: #6b7280;
}

.logout-icon {
  font-size: 32rpx !important;
}

.version {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #3b82f6;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}
