<view class="profile-page">
  <!-- 导航栏 -->
  <view class="nav-header">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">个人中心</text>
  </view>

  <scroll-view class="content-scroll" scroll-y>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-header">
        <view class="user-avatar">
          <text>👨</text>
        </view>
        <view class="user-info">
          <text class="user-name">{{userInfo ? userInfo.nickName : '小明'}}</text>
          <text class="user-type">微信用户</text>
        </view>
      </view>

      <view class="user-stats">
        <view class="stat-box">
          <text class="stat-label">记账天数</text>
          <text class="stat-value">28</text>
        </view>
        <view class="stat-box">
          <text class="stat-label">总笔数</text>
          <text class="stat-value">{{userStats.totalCount || 156}}</text>
        </view>
        <view class="stat-box">
          <text class="stat-label">总支出</text>
          <text class="stat-value">8.5k</text>
        </view>
      </view>
    </view>

    <!-- 我的统计 -->
    <view class="section">
      <text class="section-title">我的统计</text>
      <view class="menu-list">
        <view class="menu-card" bindtap="goToStatistics">
          <view class="menu-icon blue">
            <text>📊</text>
          </view>
          <text class="menu-title">我的消费统计</text>
          <text class="menu-arrow">›</text>
        </view>

        <view class="menu-card" bindtap="goToRecordList">
          <view class="menu-icon purple">
            <text>📝</text>
          </view>
          <text class="menu-title">我的记账记录</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 设置 -->
    <view class="section">
      <text class="section-title">设置</text>
      <view class="menu-list">
        <view class="menu-card" bindtap="goToLedgerList">
          <view class="menu-icon yellow">
            <text>🔔</text>
          </view>
          <text class="menu-title">记账提醒</text>
          <view class="menu-extra">
            <text class="extra-text">每晚21:00</text>
            <text class="menu-arrow">›</text>
          </view>
        </view>

        <view class="menu-card">
          <view class="menu-icon green">
            <text>📄</text>
          </view>
          <text class="menu-title">数据导出</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 关于 -->
    <view class="section">
      <text class="section-title">关于</text>
      <view class="menu-list">
        <view class="menu-card">
          <view class="menu-icon indigo">
            <text>❓</text>
          </view>
          <text class="menu-title">使用帮助</text>
          <text class="menu-arrow">›</text>
        </view>

        <view class="menu-card">
          <view class="menu-icon teal">
            <text>📋</text>
          </view>
          <text class="menu-title">隐私政策</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <view class="logout-btn" bindtap="logout">
        <text class="logout-icon">↪</text>
        <text>退出登录</text>
      </view>
      <text class="version">秒拍帐 v1.0.0</text>
    </view>
  </scroll-view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
