<!-- pages/ledger-create/ledger-create.wxml -->
<navigation-bar title="创建账本" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="create-container">
    <!-- 表单 -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label required">账本名称</text>
        <input
          class="form-input"
          placeholder="请输入账本名称"
          value="{{name}}"
          bindinput="onNameInput"
          maxlength="50"
          auto-focus
        />
      </view>

      <view class="form-item">
        <text class="form-label">账本描述</text>
        <textarea
          class="form-textarea"
          placeholder="请输入账本描述（选填）"
          value="{{description}}"
          bindinput="onDescInput"
          maxlength="100"
          show-confirm-bar="{{false}}"
        />
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tips-section">
      <view class="tip-item">
        <text class="tip-icon">💡</text>
        <text class="tip-text">账本名称将用于识别您的记账记录</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">👥</text>
        <text class="tip-text">创建后可以邀请其他人加入该账本</text>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 底部操作栏 -->
<view class="bottom-actions">
  <view class="btn btn-cancel" bindtap="onCancel">取消</view>
  <view class="btn btn-confirm" bindtap="onConfirm">创建</view>
</view>

<!-- 加载状态 -->
<view class="loading-mask" wx:if="{{loading}}">
  <text class="loading-text">创建中...</text>
</view>
