<!-- pages/index/index.wxml -->
<view class="page-container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-top">
      <view class="header-title">
        <text class="ledger-name">{{currentLedger.name || '我们的小家账本'}}</text>
        <text class="month-label">3月账单</text>
      </view>
      <view class="header-settings" bindtap="switchLedger">
        <view class="settings-icon">
          <text class="icon-gear">⚙</text>
        </view>
      </view>
    </view>

    <!-- 本月支出卡片 -->
    <view class="expense-card">
      <text class="expense-label">本月支出</text>
      <text class="expense-amount">¥{{monthlyTotal}}</text>
      <view class="expense-stats">
        <view class="stat-item">
          <text class="stat-label">日均：</text>
          <text class="stat-value">¥{{dailyAverage}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">笔数：</text>
          <text class="stat-value">{{recordCount}}</text>
        </view>
      </view>
    </view>

    <!-- 快速入口 -->
    <view class="quick-actions">
      <view class="action-item" bindtap="goToStatistics">
        <view class="action-icon blue">
          <text>📊</text>
        </view>
        <text class="action-label blue-text">统计</text>
      </view>
      <view class="action-item" bindtap="goToRecordList">
        <view class="action-icon purple">
          <text>📝</text>
        </view>
        <text class="action-label purple-text">记录</text>
      </view>
      <view class="action-item" bindtap="goToProfile">
        <view class="action-icon pink">
          <text>👥</text>
        </view>
        <text class="action-label pink-text">成员</text>
      </view>
    </view>
  </view>

  <!-- 最近记录 -->
  <scroll-view class="records-scroll" scroll-y>
    <view class="records-section">
      <text class="section-title">最近记录</text>

      <view class="records-list" wx:if="{{recentRecords.length > 0}}">
        <view
          class="record-card"
          wx:for="{{recentRecords}}"
          wx:key="_id"
          bindtap="goToRecordDetail"
          data-id="{{item._id}}"
        >
          <view class="record-emoji">
            <text>{{item.categoryEmoji || '📦'}}</text>
          </view>
          <view class="record-info">
            <view class="record-meta">
              <text class="record-category">{{item.categoryName || item.category}}</text>
              <text class="record-dot">·</text>
              <text class="record-user">{{item.payerName || '我'}}</text>
            </view>
            <text class="record-detail">{{item.merchantName || '其他'}} · {{formatDate(item.paymentTime)}}</text>
          </view>
          <text class="record-amount">-¥{{item.amount.toFixed(2)}}</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:else>
        <text class="empty-icon">📝</text>
        <text class="empty-title">暂无记账记录</text>
        <text class="empty-hint">点击下方按钮开始记账</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部添加按钮 -->
  <view class="fab-container">
    <view class="fab-add" bindtap="goToAddRecord">
      <text class="fab-icon">+</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
