/* pages/login/login.wxss */
page {
  height: 100vh;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #ec4899 100%);
}

.login-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

/* Logo区域 */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(16rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.logo {
  font-size: 100rpx;
  line-height: 1;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 400;
}

/* 登录内容区 */
.login-content {
  width: 100%;
  display: flex;
  justify-content: center;
}

/* 登录按钮 */
.login-btn {
  width: 560rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #ffffff;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
  border: none;
  transition: transform 0.2s;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  background: #f3f4f6;
}

.login-btn[disabled] {
  opacity: 0.7;
}

.login-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.login-text {
  font-size: 34rpx;
  color: #3b82f6;
  font-weight: 600;
  white-space: nowrap;
  line-height: 1;
}

.btn-loading {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.btn-loading text {
  font-size: 32rpx;
  color: #3b82f6;
  font-weight: 500;
  white-space: nowrap;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #dbeafe;
  border-top-color: #3b82f6;
  animation: spin 1s linear infinite;
  flex-shrink: 0;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 禁用状态 */
.login-btn.disabled {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

/* 用户协议 */
.agreement {
  position: fixed;
  bottom: 60rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 48rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.agreement-link {
  font-size: 24rpx;
  color: #fff;
  text-decoration: underline;
  font-weight: 500;
}
