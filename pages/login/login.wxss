/* pages/login/login.wxss */
page {
  height: 100vh;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #ec4899 100%);
}

.login-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

/* Logo区域 */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(16rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.logo {
  font-size: 100rpx;
  line-height: 1;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 400;
}

/* 登录内容区 */
.login-content {
  width: 100%;
  max-width: 600rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 112rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f3f4f6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  color: #3b82f6;
  font-weight: 600;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
  border: none;
  margin-bottom: 48rpx;
  transition: transform 0.2s;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
}

.login-btn[disabled] {
  opacity: 0.7;
}

.login-icon {
  font-size: 40rpx;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #dbeafe;
  border-top-color: #3b82f6;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 禁用状态 */
.login-btn.disabled {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

/* 功能说明卡片 */
.features-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 40rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(16rpx);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.feature-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.feature-icon-wrapper.blue {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.feature-icon-wrapper.purple {
  background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%);
}

.feature-icon-wrapper.pink {
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
}

.feature-icon {
  font-size: 44rpx;
  line-height: 1;
}

.feature-text {
  font-size: 26rpx;
  color: #4b5563;
  font-weight: 500;
}

.divider {
  width: 2rpx;
  height: 80rpx;
  background: linear-gradient(180deg, transparent 0%, #e5e7eb 50%, transparent 100%);
}

/* 用户协议 */
.agreement {
  position: fixed;
  bottom: 60rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 48rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.agreement-link {
  font-size: 24rpx;
  color: #fff;
  text-decoration: underline;
  font-weight: 500;
}
