/* pages/login/login.wxss */
page {
  height: 100vh;
  background: linear-gradient(135deg, #eff6ff 0%, #faf5ff 50%, #fdf2f8 100%);
}

.login-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 装饰性背景圆圈 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  pointer-events: none;
}

.circle-1 {
  top: 80rpx;
  right: -80rpx;
  width: 512rpx;
  height: 512rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(139, 92, 246, 0.2) 100%);
}

.circle-2 {
  bottom: -80rpx;
  left: -80rpx;
  width: 576rpx;
  height: 576rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(236, 72, 153, 0.2) 100%);
}

/* 主要内容 */
.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  position: relative;
  z-index: 10;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 96rpx;
}

.app-icon {
  width: 192rpx;
  height: 192rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #ec4899 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  box-shadow: 0 32rpx 64rpx rgba(139, 92, 246, 0.3);
}

.icon-camera {
  font-size: 96rpx;
  color: #fff;
}

.app-name {
  font-size: 72rpx;
  font-weight: 700;
  background: linear-gradient(90deg, #2563eb 0%, #7c3aed 50%, #db2777 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 24rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #6b7280;
}

/* 特性展示 */
.features-section {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(8rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-icon.blue {
  background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
}

.feature-icon.purple {
  background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%);
}

.feature-icon.pink {
  background: linear-gradient(135deg, #f472b6 0%, #ec4899 100%);
}

.feature-icon text {
  font-size: 40rpx;
  color: #fff;
}

.feature-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.feature-title {
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 500;
}

.feature-desc {
  font-size: 26rpx;
  color: #6b7280;
}

/* 底部登录区域 */
.login-footer {
  padding: 0 64rpx 96rpx;
  position: relative;
  z-index: 10;
}

/* 微信登录按钮 */
.login-btn {
  width: 100%;
  height: 112rpx;
  border-radius: 56rpx;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 50%, #ec4899 100%);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 16rpx 48rpx rgba(139, 92, 246, 0.3);
  border: none;
  margin-bottom: 32rpx;
  transition: transform 0.2s;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
}

.login-btn[disabled] {
  opacity: 0.7;
}

.wechat-icon {
  font-size: 48rpx;
}

.btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.btn-loading {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 禁用状态 */
.login-btn.disabled {
  background: rgba(107, 114, 128, 0.3);
}

.login-btn.disabled .btn-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

/* 协议文案 */
.agreement {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.agreement-text {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.agreement-link {
  font-size: 24rpx;
  color: #8b5cf6;
  line-height: 1.6;
}
