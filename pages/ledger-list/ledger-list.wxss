/* pages/ledger-list/ledger-list.wxss */
page {
  height: 100vh;
  background: linear-gradient(180deg, rgba(239, 246, 255, 0.5) 0%, #ffffff 100%);
}

.ledger-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 48rpx 32rpx;
  border-bottom: 2rpx solid #dbeafe;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dbeafe 0%, #e9d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #3b82f6;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
  overflow: hidden;
}

/* 区块 */
.section {
  padding: 32rpx 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #374151;
}

.section-title-single {
  font-size: 36rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 24rpx;
}

/* 创建按钮 */
.create-btn {
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.create-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.create-icon {
  font-size: 32rpx !important;
  font-weight: 600;
}

/* 账本列表 */
.ledger-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.ledger-card {
  padding: 32rpx;
  background: #fff;
  border-radius: 32rpx;
  border: 4rpx solid #e5e7eb;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.ledger-card.active {
  border-color: #3b82f6;
  background: linear-gradient(135deg, #eff6ff 0%, #f5f3ff 100%);
}

.ledger-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.ledger-info {
  flex: 1;
}

.ledger-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.ledger-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 26rpx;
  color: #6b7280;
}

.current-badge {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.ledger-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.expense-label {
  font-size: 26rpx;
  color: #6b7280;
}

.expense-amount {
  flex: 1;
  margin-left: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.manage-link {
  font-size: 28rpx;
  color: #6b7280;
}

/* 邀请按钮 */
.invite-btn {
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  border: 4rpx solid #dbeafe;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.invite-btn text {
  font-size: 28rpx;
  color: #3b82f6;
  font-weight: 500;
}

.invite-icon {
  font-size: 28rpx !important;
}

/* 邀请码卡片 */
.invite-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #faf5ff 100%);
  border: 2rpx solid #dbeafe;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.invite-tip {
  font-size: 28rpx;
  color: #1e40af;
  display: block;
  margin-bottom: 24rpx;
}

.invite-code-wrapper {
  display: flex;
  gap: 16rpx;
}

.code-box {
  flex: 1;
  height: 96rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 2rpx solid #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.code-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #3b82f6;
  letter-spacing: 16rpx;
}

.copy-btn {
  height: 96rpx;
  padding: 0 48rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.copy-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

/* 成员列表 */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #f3f4f6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fbcfe8 0%, #f9a8d4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.member-avatar text {
  font-size: 48rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 32rpx;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.member-role {
  font-size: 26rpx;
  color: #6b7280;
}

/* 设置列表 */
.settings-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #f3f4f6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.setting-item:active {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.setting-item.delete {
  background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
  border-color: #fecaca;
}

.setting-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.setting-icon.blue {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.setting-icon.purple {
  background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%);
}

.setting-icon.red {
  background: linear-gradient(135deg, #fecaca 0%, #fca5a5 100%);
}

.setting-icon text {
  font-size: 36rpx;
}

.setting-title {
  flex: 1;
  font-size: 30rpx;
  color: #374151;
}

.setting-title.delete-text {
  color: #dc2626;
}

.setting-arrow {
  font-size: 36rpx;
  color: #9ca3af;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #3b82f6;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}
