/* pages/statistics/statistics.wxss */
page {
  height: 100vh;
  background: linear-gradient(180deg, rgba(239, 246, 255, 0.5) 0%, #ffffff 100%);
}

.statistics-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 48rpx 32rpx;
  border-bottom: 2rpx solid #dbeafe;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dbeafe 0%, #e9d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #3b82f6;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
  overflow: hidden;
}

/* 时间选择器 */
.time-selector {
  padding: 32rpx 48rpx;
}

.time-btn {
  height: 96rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(90deg, #dbeafe 0%, #e9d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.time-text {
  font-size: 32rpx;
  color: #1e3a8a;
  font-weight: 500;
}

.time-arrow {
  font-size: 28rpx;
  color: #3b82f6;
}

/* 总支出 */
.total-section {
  padding: 0 48rpx 32rpx;
}

.total-label {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 12rpx;
}

.total-amount {
  font-size: 64rpx;
  font-weight: 700;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 图表容器 */
.chart-wrapper {
  height: 500rpx;
  padding: 0 48rpx;
  margin-bottom: 32rpx;
}

.chart-container {
  width: 100%;
  height: 100%;
}

/* 详情区块 */
.detail-section {
  padding: 0 48rpx 48rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 32rpx;
}

/* 分类列表 */
.category-list,
.member-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-card,
.member-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f3f4f6;
}

.category-emoji {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dbeafe 0%, #e9d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.category-emoji text {
  font-size: 48rpx;
}

.category-info,
.member-info {
  flex: 1;
  min-width: 0;
}

.category-header,
.member-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.category-name,
.member-name {
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 500;
}

.category-percent,
.member-percent {
  font-size: 26rpx;
  color: #6b7280;
}

.progress-bar {
  height: 16rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.member-progress {
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
}

.category-amount,
.member-amount {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  flex-shrink: 0;
}

/* 成员卡片 */
.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fbcfe8 0%, #f9a8d4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.member-avatar text {
  font-size: 48rpx;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #3b82f6;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}
