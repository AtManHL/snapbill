.statistics-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-top: 88rpx;
  padding-bottom: 40rpx;
}

/* 账本信息 */
.ledger-info {
  padding: 20rpx 32rpx;
  background-color: #ffffff;
}

.ledger-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

/* 时间选择器 */
.time-selector {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx 0;
  margin-top: 16rpx;
}

.time-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.time-item.active {
  color: #45B7D1;
  font-weight: 600;
}

.time-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #45B7D1;
  border-radius: 3rpx;
}

/* 汇总数据 */
.summary-card {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  padding: 32rpx 0;
  margin-top: 16rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

/* 图表区域 */
.chart-section {
  background-color: #ffffff;
  margin-top: 16rpx;
  padding: 32rpx 0;
}

.chart-title {
  padding: 0 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.chart-container {
  width: 100%;
  height: 500rpx;
}

/* 分类列表 */
.category-list {
  background-color: #ffffff;
  margin-top: 16rpx;
  padding: 32rpx;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.category-items {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.category-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}

.category-name {
  font-size: 28rpx;
  color: #333333;
}

.category-amount {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.percentage {
  font-size: 24rpx;
  color: #999999;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-text {
  font-size: 28rpx;
  color: #ffffff;
}
