<view class="statistics-page">
  <!-- 导航栏 -->
  <navigation-bar
    title="统计分析"
    background="#ffffff"
    color="#333333"
    bind:back="goBack"
  />

  <!-- 账本信息 -->
  <view class="ledger-info">
    <text class="ledger-name">{{currentLedger.name}}</text>
  </view>

  <!-- 时间选择器 -->
  <view class="time-selector">
    <view
      class="time-item {{timeType === 'day' ? 'active' : ''}}"
      data-type="day"
      bindtap="switchTimeType"
    >
      日
    </view>
    <view
      class="time-item {{timeType === 'week' ? 'active' : ''}}"
      data-type="week"
      bindtap="switchTimeType"
    >
      周
    </view>
    <view
      class="time-item {{timeType === 'month' ? 'active' : ''}}"
      data-type="month"
      bindtap="switchTimeType"
    >
      月
    </view>
    <view
      class="time-item {{timeType === 'year' ? 'active' : ''}}"
      data-type="year"
      bindtap="switchTimeType"
    >
      年
    </view>
  </view>

  <!-- 汇总数据 -->
  <view class="summary-card">
    <view class="summary-item">
      <text class="summary-label">总支出</text>
      <text class="summary-value">¥{{summary.total}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">笔数</text>
      <text class="summary-value">{{summary.count}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">平均</text>
      <text class="summary-value">¥{{summary.avg}}</text>
    </view>
  </view>

  <!-- 分类统计饼图 -->
  <view class="chart-section">
    <view class="chart-title">分类统计</view>
    <view class="chart-container">
      <ec-canvas
        id="pie-chart"
        canvas-id="pie-chart"
        ec="{{ { onInit: initPieChart } }}"
      ></ec-canvas>
    </view>
  </view>

  <!-- 分类列表 -->
  <view class="category-list">
    <view class="category-title">分类明细</view>
    <view class="category-items">
      <view wx:for="{{categoryData}}" wx:key="name" class="category-item">
        <view class="category-info">
          <view class="category-dot" style="background-color: {{item.color || '#FF6B6B'}};"></view>
          <text class="category-name">{{item.name}}</text>
        </view>
        <view class="category-amount">
          <text class="amount">¥{{item.amount.toFixed(2)}}</text>
          <text class="percentage">{{item.percentage}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 趋势统计折线图 -->
  <view class="chart-section">
    <view class="chart-title">支出趋势</view>
    <view class="chart-container">
      <ec-canvas
        id="line-chart"
        canvas-id="line-chart"
        ec="{{ { onInit: initLineChart } }}"
      ></ec-canvas>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <text class="loading-text">加载中...</text>
  </view>
</view>
