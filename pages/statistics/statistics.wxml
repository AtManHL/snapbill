<view class="statistics-page">
  <!-- 导航栏 -->
  <view class="nav-header">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">统计分析</text>
  </view>

  <scroll-view class="content-scroll" scroll-y>
    <!-- 时间选择 -->
    <view class="time-selector">
      <view class="time-btn" bindtap="showTimePicker">
        <text class="time-text">{{currentYear}}年{{currentMonth}}月</text>
        <text class="time-arrow">▼</text>
      </view>
    </view>

    <!-- 总支出 -->
    <view class="total-section">
      <text class="total-label">总支出</text>
      <text class="total-amount">¥{{summary.total}}</text>
    </view>

    <!-- 饼图 -->
    <view class="chart-wrapper">
      <view class="chart-container">
        <ec-canvas
          id="pie-chart"
          canvas-id="pie-chart"
          ec="{{ { onInit: initPieChart } }}"
        ></ec-canvas>
      </view>
    </view>

    <!-- 分类明细 -->
    <view class="detail-section">
      <text class="section-title">分类明细</text>
      <view class="category-list">
        <view wx:for="{{categoryData}}" wx:key="name" class="category-card">
          <view class="category-emoji" style="background: {{item.gradient}};">
            <text>{{item.emoji}}</text>
          </view>
          <view class="category-info">
            <view class="category-header">
              <text class="category-name">{{item.name}}</text>
              <text class="category-percent">{{item.percentage}}%</text>
            </view>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.percentage}}%; background: {{item.color}};"></view>
            </view>
          </view>
          <text class="category-amount">¥{{item.amount.toFixed(2)}}</text>
        </view>
      </view>
    </view>

    <!-- 成员统计 -->
    <view class="detail-section">
      <text class="section-title">成员统计</text>
      <view class="member-list">
        <view wx:for="{{memberData}}" wx:key="name" class="member-card">
          <view class="member-avatar">
            <text>{{item.avatar}}</text>
          </view>
          <view class="member-info">
            <view class="member-header">
              <text class="member-name">{{item.name}}</text>
              <text class="member-percent">{{item.percentage}}%</text>
            </view>
            <view class="progress-bar">
              <view class="progress-fill member-progress" style="width: {{item.percentage}}%;"></view>
            </view>
          </view>
          <text class="member-amount">¥{{item.amount.toFixed(2)}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
