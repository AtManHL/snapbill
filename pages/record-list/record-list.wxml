<view class="record-list-page">
  <!-- 导航栏 -->
  <view class="nav-header">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">历史记录</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索金额或分类"
        value="{{keyword}}"
        bindinput="onSearch"
      />
    </view>
    <view class="filter-btn" bindtap="showFilter">
      <text class="filter-icon">⚙</text>
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y bindscrolltolower="loadMore">
    <!-- 按日期分组显示 -->
    <view class="records-container">
      <view wx:for="{{groupedRecords}}" wx:key="date" class="date-group">
        <view class="date-header">
          <text class="date-label">{{item.label}}</text>
          <text class="date-count">共 {{item.count}} 笔</text>
        </view>

        <view class="records-list">
          <view
            wx:for="{{item.records}}"
            wx:for-item="record"
            wx:key="_id"
            class="record-card"
            bindtap="goToDetail"
            data-id="{{record._id}}"
          >
            <view class="record-emoji">
              <text>{{record.categoryIcon || '📦'}}</text>
            </view>
            <view class="record-info">
              <view class="record-meta">
                <text class="record-category">{{record.categoryName}}</text>
                <text class="record-dot">·</text>
                <text class="record-user">{{record.payerName || '我'}}</text>
              </view>
              <text class="record-detail">{{formatTime(record.paymentTime)}}</text>
            </view>
            <text class="record-amount">-¥{{record.amount.toFixed(2)}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{records.length === 0}}">
      <text class="empty-icon">📝</text>
      <text class="empty-title">暂无记录</text>
      <text class="empty-hint">点击首页的+开始记账</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore && records.length > 0}}">
      <text class="load-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
      <text class="load-text">没有更多了</text>
    </view>
  </scroll-view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
