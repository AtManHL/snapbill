<!-- pages/record-list/record-list.wxml -->
<navigation-bar title="历史记录" back="{{true}}" color="black" background="#FFF">
  <view slot="right" class="nav-right">
    <text class="nav-icon" bindtap="goHome">🏠</text>
  </view>
</navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list" bindscrolltolower="loadMore">
  <view class="record-list-container">
    <!-- 搜索栏 -->
    <view class="search-bar">
      <input
        class="search-input"
        placeholder="搜索记录..."
        value="{{keyword}}"
        bindinput="onSearch"
      />
    </view>

    <!-- 筛选标签 -->
    <scroll-view class="filter-tags" scroll-x>
      <view
        class="tag {{activeCategory === '' ? 'active' : ''}}"
        bindtap="filterByCategory"
        data-id=""
      >
        全部
      </view>
      <view
        wx:for="{{categories}}"
        wx:key="_id"
        class="tag {{activeCategory === item._id ? 'active' : ''}}"
        bindtap="filterByCategory"
        data-id="{{item._id}}"
      >
        {{item.icon}} {{item.name}}
      </view>
    </scroll-view>

    <!-- 记录列表 -->
    <view class="record-list" wx:if="{{records.length > 0}}">
      <view
        class="record-item"
        wx:for="{{records}}"
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <view class="record-left">
          <text class="record-icon">{{item.categoryName}}</text>
          <view class="record-info">
            <text class="record-merchant">{{item.merchantName || '其他'}}</text>
            <text class="record-time">{{formatDate(item.paymentTime)}}</text>
          </view>
        </view>
        <view class="record-right">
          <text class="record-amount">-{{formatAmount(item.amount)}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无记录</text>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{hasMore && records.length > 0}}">
      <text class="load-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
      <text class="load-text">没有更多了</text>
    </view>
  </view>
</scroll-view>

<!-- 加载状态 -->
<view class="loading-mask" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
