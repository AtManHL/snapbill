/* pages/record-list/record-list.wxss */
page {
  height: 100vh;
  background: linear-gradient(180deg, rgba(239, 246, 255, 0.5) 0%, #ffffff 100%);
}

.record-list-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 48rpx 32rpx;
  border-bottom: 2rpx solid #dbeafe;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dbeafe 0%, #e9d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #3b82f6;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 搜索区域 */
.search-section {
  display: flex;
  gap: 16rpx;
  padding: 32rpx 48rpx;
}

.search-box {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(90deg, #eff6ff 0%, #faf5ff 100%);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #60a5fa;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
}

.filter-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #dbeafe 0%, #e9d5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.filter-icon {
  font-size: 36rpx;
  color: #3b82f6;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
  overflow: hidden;
}

.records-container {
  padding: 0 48rpx 48rpx;
}

/* 日期分组 */
.date-group {
  margin-bottom: 48rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}

.date-label {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 500;
}

.date-count {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 记录列表 */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f3f4f6;
}

.record-card:active {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.record-emoji {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.record-emoji text {
  font-size: 48rpx;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.record-category {
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 500;
}

.record-dot {
  font-size: 24rpx;
  color: #d1d5db;
}

.record-user {
  font-size: 26rpx;
  color: #6b7280;
}

.record-detail {
  font-size: 24rpx;
  color: #9ca3af;
}

.record-amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #374151;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 36rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载更多 */
.load-more,
.no-more {
  text-align: center;
  padding: 48rpx 0;
}

.load-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #3b82f6;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}
